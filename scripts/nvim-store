#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
local_home=${NVIM_PACK_LOCAL_HOME:-"$repo_root/.local/store"}
runtime_dir="$local_home/run"
home_dir=${HOME:-/home/max}
manifest=${NVIM_PACK_MANIFEST:-"$home_dir/.dotfiles/result/home-files/.config/nvim/lua/custom/pack/manifest.lua"}

mkdir -p "$runtime_dir"
chmod 700 "$runtime_dir"

if [ ! -r "$manifest" ]; then
  printf 'Missing Neovim plugin manifest: %s\n' "$manifest" >&2
  printf 'Build it from ~/.dotfiles with:\n' >&2
  printf '  nix build .#nixosConfigurations.maxbook.config.home-manager.users.max.home.activationPackage\n' >&2
  exit 1
fi

export XDG_CONFIG_HOME="$local_home/config"
export XDG_DATA_HOME="$local_home/share"
export XDG_STATE_HOME="$local_home/state"
export XDG_CACHE_HOME="$local_home/cache"
export XDG_RUNTIME_DIR="$runtime_dir"
export NVIM_APPNAME="nvim"
export NVIM_PACK_CONFIG_ROOT="$repo_root"
export NVIM_PACK_BACKEND="nix_manifest"
export NVIM_PACK_MANIFEST="$manifest"
export NVIM_PACK_MODE="secure"
export NVIM_PACK_TRUSTED_PREFIX="/nix/store/"
export NVIM_TREESITTER_INSTALL="${NVIM_TREESITTER_INSTALL:-disabled}"
export NVIM_LOG_FILE="${NVIM_LOG_FILE:-$repo_root/.nvimlog}"

exec nvim -u "$repo_root/init.lua" "$@"
