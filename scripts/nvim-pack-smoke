#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
smoke="$repo_root/.github/pack-smoke.lua"

if [ -n "${NVIM_PACK_GENERATED_CONFIG:-}" ]; then
  init="$NVIM_PACK_GENERATED_CONFIG"
  config_home=$(dirname "$(dirname "$init")")
  local_home=${NVIM_PACK_LOCAL_HOME:-"$repo_root/.local/generated-smoke"}
  runtime_dir="$local_home/run"

  if [ ! -r "$init" ]; then
    printf 'Missing generated Neovim init.lua: %s\n' "$init" >&2
    exit 1
  fi

  mkdir -p "$runtime_dir"
  chmod 700 "$runtime_dir"

  export XDG_CONFIG_HOME="$config_home"
  export XDG_DATA_HOME="$local_home/share"
  export XDG_STATE_HOME="$local_home/state"
  export XDG_CACHE_HOME="$local_home/cache"
  export XDG_RUNTIME_DIR="$runtime_dir"
  export NVIM_APPNAME="${NVIM_APPNAME:-nvim}"
  export NVIM_PLUGIN_BACKEND="${NVIM_PLUGIN_BACKEND:-pack_nix}"

  exec nvim --headless --cmd "set runtimepath^=$config_home/nvim" -u "$init" -l "$smoke"
fi

"$script_dir/nvim-isolated" --headless -l "$smoke"
