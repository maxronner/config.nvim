#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
local_home=${NVIM_PACK_LOCAL_HOME:-"$repo_root/.local/isolated"}
runtime_dir="$local_home/run"

mkdir -p "$runtime_dir"
chmod 700 "$runtime_dir"

export XDG_CONFIG_HOME="$local_home/config"
export XDG_DATA_HOME="$local_home/share"
export XDG_STATE_HOME="$local_home/state"
export XDG_CACHE_HOME="$local_home/cache"
export XDG_RUNTIME_DIR="$runtime_dir"
export NVIM_APPNAME="nvim"
export NVIM_PACK_CONFIG_ROOT="$repo_root"
export NVIM_LOG_FILE="${NVIM_LOG_FILE:-$repo_root/.nvimlog}"

exec nvim -u "$repo_root/init.lua" "$@"
